# APP
APP_NAME=LearnPath AI
APP_ENV=development

# SERVER
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001

# DATABASE

MONGODB_DB_NAME=learnpath_ai

# GROQ
GROQ_API_KEY=GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# AI
USE_MOCK_AI=false